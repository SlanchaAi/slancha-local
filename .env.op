# Managed by 1Password. Run via: op run --env-file=.env.op -- <cmd>
# Secrets are op:// references (vault Slancha). Safe to commit.
# slancha-local test environment
# This file is .gitignored. Fill in the keys you want active; leave others blank.
# See docs/launch/API-KEYS.md for what each one gates and how to obtain it.

# ============================================================================
# CLASSIFIER MODE — local (default; zero network) | cloud (slancha-api) | rules
# ============================================================================
# Default: local. Switch to "cloud" if testing the slancha cloud classifier path.
SLANCHA_CLASSIFIER_KIND=local
SLANCHA_API_KEY=op://Slancha/shared-ai-keys/SLANCHA_API_KEY
# SLANCHA_API_BASE_URL=https://api.slancha.ai

# ============================================================================
# JUDGE MODEL — used by train/eval.py::judge_pairwise_pick for FT promotion
# ============================================================================
# Resolution order (first set wins):
#   1. SLANCHA_TRAIN_DRY_RUN=1 → 'tie' (zero network; tests use this)
#   2. SLANCHA_JUDGE_URL set    → POST OpenAI-compat to that URL
#   3. SLANCHA_API_KEY set      → slancha cloud /v1/chat/completions
#   4. OPENAI_API_KEY set       → OpenAI gpt-4o-mini (cheapest reasonable judge)
#   5. else                     → 'tie' fallback (promotion blocked)
OPENAI_API_KEY=op://Slancha/shared-ai-keys/OPENAI_API_KEY
# SLANCHA_JUDGE_URL=
# SLANCHA_JUDGE_API_KEY=
# SLANCHA_JUDGE_MODEL=gpt-4o-mini

# ============================================================================
# FINE-TUNE PROVIDERS — train/providers/http_providers.py
# ============================================================================
# Set SLANCHA_TRAIN_DRY_RUN=1 to short-circuit all real provider calls.
# Tests force this on; .env value is ignored under pytest.
# SLANCHA_TRAIN_DRY_RUN=0   # uncomment to actually hit the FT APIs

# Fireworks (LoRA fine-tuning, ~$0.40/1M training tokens)
FIREWORKS_API_KEY=op://Slancha/shared-ai-keys/FIREWORKS_API_KEY
FIREWORKS_ACCOUNT_ID=op://Slancha/shared-ai-keys/FIREWORKS_ACCOUNT_ID

# Together (alt LoRA path, broader catalog)
TOGETHER_API_KEY=op://Slancha/shared-ai-keys/TOGETHER_API_KEY

# Openrouter 
OPENROUTER_API_KEY=op://Slancha/shared-ai-keys/OPENROUTER_API_KEY

# (OPENAI_API_KEY above also unlocks the OpenAIProvider FT path,
#  though OpenAI doesn't expose LoRA — full-SFT only.)

# ============================================================================
# HUGGINGFACE — for downloading gated models on Spark + pushing LoRA artifacts
# ============================================================================
HF_TOKEN=op://Slancha/shared-ai-keys/HF_TOKEN

# ============================================================================
# CLICKHOUSE — analytics fan-out (only when SLANCHA_TRAIN_STORAGE=clickhouse)
# ============================================================================
# SLANCHA_TRAIN_STORAGE=clickhouse
# CLICKHOUSE_HOST=127.0.0.1
# CLICKHOUSE_PORT=8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default

# ============================================================================
# BACKENDS — local servers (override defaults if you bind to non-standard ports)
# ============================================================================
# SLANCHA_OLLAMA_BASE_URL=http://127.0.0.1:11434
# SLANCHA_LLAMACPP_BASE_URL=http://127.0.0.1:8080
# SLANCHA_VLLM_BASE_URL=http://127.0.0.1:8000
# SLANCHA_VLLM_ENABLED=false
# SLANCHA_MLX_BASE_URL=http://127.0.0.1:8081
# SLANCHA_MLX_ENABLED=false
# SLANCHA_LMSTUDIO_BASE_URL=http://127.0.0.1:1234
# SLANCHA_LMSTUDIO_ENABLED=false
# SLANCHA_GENERIC_OPENAI_BASE_URL=

# ============================================================================
# MULTIMODAL — opt-in
# ============================================================================
# SLANCHA_COMFY_ENABLED=false
# SLANCHA_COMFY_BASE_URL=http://127.0.0.1:8188
# SLANCHA_COMFY_DEFAULT_WORKFLOW=

# ============================================================================
# OBSERVABILITY — opt-in trace sharing
# ============================================================================
# SLANCHA_SHARE_PROMPTS=false
# SLANCHA_SHARE_TRACES=false
# SLANCHA_TRACES_ROOT=~/.slancha/traces

# ============================================================================
# ANTI-PATTERN — DO NOT SET
# ============================================================================
ANTHROPIC_API_KEY=op://Slancha/shared-ai-keys/ANTHROPIC_API_KEY
